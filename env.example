# Firebase Configuration
# Expo bundles env vars into the JS only when prefixed EXPO_PUBLIC_*. Anything
# else (including the legacy REACT_APP_*) will be undefined at runtime.
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# OpenAI API Key (for backend)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (for backend)
GEMINI_API_KEY=your_gemini_api_key_here

# Dev-only VRF test harness
EXPO_PUBLIC_ENABLE_VRF_DEV_SCREEN=0

# Privy (auth + embedded wallets)
# Register an app at https://dashboard.privy.io and paste the App ID + Client ID below.
EXPO_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here
EXPO_PUBLIC_PRIVY_CLIENT_ID=your_privy_client_id_here
