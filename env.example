# Firebase Configuration
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# OpenAI API Key (for backend)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (for backend)
GEMINI_API_KEY=your_gemini_api_key_here 

# Xai Grok API KEY (for backend)
XAI_API_KEY=your_grok_api_key_here

# Dev-only VRF test harness
EXPO_PUBLIC_ENABLE_VRF_DEV_SCREEN=0

# Privy (auth + embedded wallets)
# Register an app at https://dashboard.privy.io and paste the App ID + Client ID below.
EXPO_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here
EXPO_PUBLIC_PRIVY_CLIENT_ID=your_privy_client_id_here
